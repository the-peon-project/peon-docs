meta {
  name: Delete Server & Remove Local Files
  type: http
  seq: 8
}

delete {
  url: {{url}}:{{port}}/api/v1/server/eradicate/{{game_uid}}.{{server_name}}
  body: json
  auth: inherit
}

headers {
  X-Api-Key: {{api-key}}
}

body:json {
  { "eradicate" : true }
}

settings {
  encodeUrl: true
}
